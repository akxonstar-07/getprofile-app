generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AGENCY
  ADMIN
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
  COURSE
}

enum MessageCategory {
  FAN
  BRAND
  SALE
  SUBSCRIPTION
  OTHER
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  username       String?   @unique
  hashedPassword String?
  role           Role      @default(USER)
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Profile Role (e.g. "fitness_coach", "barber", "lawyer")
  profileRole    String?   @default("personal_brand")
  plan           String    @default("FREE") // FREE | TRIAL | PRO
  trialEndsAt    DateTime?

  accounts       Account[]
  sessions       Session[]
  profile        Profile?
  links          Link[]
  portfolioItems PortfolioItem[]
  products       Product[]
  analyticsEvents AnalyticsEvent[]
  subscribers    Subscriber[]
  promoCodes     PromoCode[]
  contentSubscriptions ContentSubscription[] @relation("CreatorSubscriptions")
  fanSubscriptions     ContentSubscription[] @relation("FanSubscriptions")
  bookings       Booking[]
  onboardingCompleted Boolean @default(false)

  // Agency specific
  managedByAgencyId String?
  agency            Agency? @relation("AgencyToCreator", fields: [managedByAgencyId], references: [id])
  ownedAgency       Agency? @relation("AgencyOwner")

  // Commerce & Messaging
  orders         Order[]
  conversations  Conversation[]
  events         Event[]

  // ═══ NEW: Community & Memberships ═══
  broadcastMessages BroadcastMessage[]
  membershipTiers   MembershipTier[]
}

model Agency {
  id          String   @id @default(cuid())
  name        String
  ownerId     String   @unique
  owner       User     @relation("AgencyOwner", fields: [ownerId], references: [id])
  creators    User[]   @relation("AgencyToCreator")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  bio         String?
  avatarUrl   String?
  bannerUrl   String?
  location    String?
  theme       String  @default("default")
  font        String  @default("Inter")
  bgColor     String  @default("#ffffff")
  accentColor String  @default("#6366f1")
  layoutStyle String  @default("minimal")
  portfolioTheme String @default("default")
  mobileTheme    String @default("default")
  monetizationGoals String?

  // ═══ NEW: Template Engine ("Style It Your Way") ═══
  activeTemplateId String?  @default("minimal-white")
  themeConfig      String?  @default("{}") // JSON: {headerStyle, colorScheme, font, buttonStyle}

  // ═══ NEW: Live Streaming ═══
  isLive    Boolean @default(false)
  liveUrl   String?

  // ═══ NEW: Fundraising / Tip Goals ═══
  tipGoalTitle    String?
  tipGoalImage    String?
  tipGoalAmount   Float?   @default(0)
  tipCurrentAmount Float?  @default(0)

  // Socials
  twitter        String?
  instagram      String?
  linkedin       String?
  youtube        String?
  github         String?
  tiktok         String?
  website        String?
  facebook       String?
  snapchat       String?
  spotify        String?
  totalFollowers Int?    @default(0)

  // Portfolio / Media Kit fields
  portfolioTitle    String?    
  portfolioBio      String?    
  skills            String?    
  brandLogos        String?    
  pressLogos        String?    
  businessEmail     String?    
  availableForWork  Boolean    @default(true)
  statsBrandDeals   Int        @default(0)
  statsContentCount Int        @default(0)

  // Device-Specific Configs (JSON)
  webConfig         String?    @default("{}") // Layout config for website view
  mobileConfig      String?    @default("{}") // Layout config for link-in-bio view

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Link {
  id        String   @id @default(cuid())
  userId    String
  title     String
  url       String
  icon      String?
  image     String?
  highlight Boolean  @default(false)
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  clicks    Int      @default(0)
  
  abTestActive Boolean @default(false)
  variantBUrl  String?
  variantBTitle String?
  clicksA      Int     @default(0)
  clicksB      Int     @default(0)

  scheduledStart DateTime?
  scheduledEnd   DateTime?

  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortfolioItem {
  id          String  @id @default(cuid())
  userId      String
  title       String
  image       String?
  description String?
  link        String?
  category    String?
  order       Int     @default(0)
  createdAt   DateTime @default(now())

  itemType    String?    
  brandName   String?    
  videoUrl    String?    

  // ═══ NEW: Content Paywalling ═══
  isLocked      Boolean  @default(false)
  unlockPrice   Float?   @default(0)
  requiredTier  String?  // "basic", "premium", "vip" — null = one-time unlock

  // ═══ NEW: Attached Commerce (PDF overlay on video) ═══
  attachedProductId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id           String      @id @default(cuid())
  userId       String
  name         String
  description  String?
  price        Float       @default(0)
  image        String?
  productType  ProductType @default(DIGITAL)
  digitalUrl   String?     // URL to digital asset (PDF, zip, etc.)
  inventory    Int?        @default(1) // For physical products
  category     String?     // e.g. "Presets", "Merch"
  enabled      Boolean     @default(true)
  order        Int         @default(0)
  isAffiliate  Boolean     @default(false)
  affiliateNote String?
  createdAt    DateTime    @default(now())

  // ═══ NEW: Affiliate Coupon Codes ═══
  couponCode   String?     // e.g. "ILoveMatcha" — copyable by fans

  // ═══ NEW: Course Structure (for productType=COURSE) ═══
  courseModules String?     @default("[]") // JSON: [{title, chapters: [{title, videoUrl, duration}]}]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

model Order {
  id          String   @id @default(cuid())
  userId      String   // The Creator selling the product
  productId   String
  customerEmail String
  amount      Float
  status      String   @default("PENDING") // PENDING, PAID, SHIPPED, etc.
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  date        DateTime
  location    String?  // URL for webinar or physical address
  isVirtual   Boolean  @default(true)
  maxAttendees Int?
  currentRSVP Int       @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  // ═══ NEW: Paid Ticketing ═══
  ticketPrice  Float?   @default(0)
  image        String?
  earlyBirdPrice Float? @default(0)
  earlyBirdEnds  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String   @id @default(cuid())
  userId      String   // The Creator
  visitorId   String?  // Optional: tracking anonymous visitors
  visitorEmail String?
  visitorName String?
  summary      String?  // AI Summary of the conversation
  lastMessageAt DateTime @default(now())
  createdAt    DateTime @default(now())

  messages Message[]
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String          @id @default(cuid())
  conversationId String
  sender         String          // "VISITOR" or "CREATOR" or "AI_ASSISTANT"
  content        String
  category       MessageCategory @default(OTHER)
  isRead         Boolean         @default(false)
  createdAt      DateTime        @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  metadata  String?
  referrer  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscriber {
  id        String   @id @default(cuid())
  userId    String
  email     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

// ═══ Stage 1: PromoCode Engine ═══
model PromoCode {
  id              String   @id @default(cuid())
  userId          String
  code            String
  discountPercent Int      @default(10)
  maxUses         Int      @default(100)
  currentUses     Int      @default(0)
  expiresAt       DateTime?
  aiTriggered     Boolean  @default(false) // Was this auto-offered by AI?
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
}

// ═══ Stage 4: Gated Content Subscriptions ═══
model ContentSubscription {
  id              String   @id @default(cuid())
  creatorId       String   // The creator offering gated content
  subscriberId    String   // The fan subscribing
  tier            String   @default("basic") // basic, premium, vip
  status          String   @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  stripeSubId     String?  // Stripe Subscription ID
  pricePerMonth   Float    @default(5.0)
  currentPeriodEnd DateTime?
  createdAt       DateTime @default(now())

  creator    User @relation("CreatorSubscriptions", fields: [creatorId], references: [id], onDelete: Cascade)
  subscriber User @relation("FanSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)
}

// ═══ Stage 5: Booking / Scheduling ═══
model Booking {
  id              String   @id @default(cuid())
  userId          String   // The creator being booked
  guestName       String
  guestEmail      String
  date            DateTime
  time            String   // e.g. "10:00 AM"
  duration        Int      @default(30) // minutes
  status          String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  preQualAnswers  String?  // JSON: {"budget": "$500", "need": "Website redesign"}
  notes           String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══ NEW: Creator Membership Tiers ═══
model MembershipTier {
  id            String   @id @default(cuid())
  userId        String   // The creator offering this tier
  title         String   // e.g. "VIP Club", "Annual Membership"
  description   String?
  pricePerMonth Float    @default(5.0)
  benefits      String?  @default("[]") // JSON: ["Exclusive content", "Early access"]
  image         String?
  color         String?  @default("#6366f1")
  enabled       Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══ NEW: Community Broadcast Messages ═══
model BroadcastMessage {
  id        String   @id @default(cuid())
  userId    String   // The creator posting
  content   String
  isPinned  Boolean  @default(false)
  tier      String?  // null = public, "basic"/"vip" = gated
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
